# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# JWT Secret — wygeneruj: openssl rand -hex 32
JWT_SECRET=wpisz_tu_losowy_klucz_minimum_32_znaki

# Token Cloudflare Tunnel — z panelu Zero Trust -> Tunnels -> Twoj tunel -> Configure -> Token
CLOUDFLARE_TUNNEL_TOKEN=wpisz_tu_token_z_cloudflare
